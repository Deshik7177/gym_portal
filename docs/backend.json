{
  "entities": {
    "Member": {
      "title": "Member",
      "description": "A gym member profile with a permanent QR ID.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "phone": { "type": "string", "description": "Primary ID" },
        "status": { "type": "string", "enum": ["active", "non-active"] },
        "type": { "type": "string", "enum": ["group", "personal"] },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "qrToken": { "type": "string", "description": "Unique permanent QR payload" },
        "price": { "type": "number" },
        "description": { "type": "string", "description": "Details about the opted package" },
        "photoData": { "type": "string" },
        "lastCheckIn": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "phone", "status", "price"]
    },
    "GateControl": {
      "title": "Gate Control",
      "description": "Real-time commands for the physical gate relay.",
      "type": "object",
      "properties": {
        "command": { "type": "string", "enum": ["OPEN", "CLOSE"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "memberId": { "type": "string" },
        "method": { "type": "string", "enum": ["qr", "manual"] }
      }
    },
    "Attendance": {
      "title": "Attendance Log",
      "description": "Historical record of entry attempts.",
      "type": "object",
      "properties": {
        "memberId": { "type": "string" },
        "memberName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "method": { "type": "string", "enum": ["qr", "manual"] },
        "latency": { "type": "number", "description": "Scan speed in ms" }
      }
    },
    "Sale": {
      "title": "Sale",
      "description": "A transaction record.",
      "type": "object",
      "properties": {
        "memberId": { "type": "string" },
        "memberName": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "category": { "type": "string", "enum": ["membership", "personal training", "other"] },
        "description": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/members/{phone}": {
      "schema": "#/backend/entities/Member",
      "description": "Gym members indexed by phone."
    },
    "/gateControl/{commandId}": {
      "schema": "#/backend/entities/GateControl",
      "description": "Real-time gate command queue."
    },
    "/attendance/{logId}": {
      "schema": "#/backend/entities/Attendance",
      "description": "Historical entry logs."
    },
    "/sales/{saleId}": {
      "schema": "#/backend/entities/Sale",
      "description": "Transaction history."
    }
  }
}